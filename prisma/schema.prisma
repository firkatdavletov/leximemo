generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

enum ReviewGrade {
  HARD
  NORMAL
  EASY
}

model User {
  id                   String               @id @default(cuid())
  email                String               @unique
  passwordHash         String
  name                 String?
  decks                Deck[]
  reviewHistory        ReviewHistory[]
  achievements         Achievement[]
  dailyStudyActivities DailyStudyActivity[]
  stats                UserStats?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
}

model Deck {
  id            String          @id @default(cuid())
  title         String
  description   String?
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards         Card[]
  reviewHistory ReviewHistory[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([userId])
}

model Card {
  id               String          @id @default(cuid())
  word             String
  translation      String
  languageCode     String?
  example          String?
  imageUrl         String?
  repetitionsCount Int             @default(0)
  intervalDays     Int             @default(0)
  easeFactor       Float           @default(2.5)
  lastReviewedAt   DateTime?
  nextReviewAt     DateTime?
  lastGrade        ReviewGrade?
  mistakesCount    Int             @default(0)
  deckId           String
  deck             Deck            @relation(fields: [deckId], references: [id], onDelete: Cascade)
  reviewHistory    ReviewHistory[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([deckId])
  @@index([nextReviewAt])
  @@index([deckId, nextReviewAt])
}

model ReviewHistory {
  id                   String      @id @default(cuid())
  userId               String
  user                 User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  deckId               String
  deck                 Deck        @relation(fields: [deckId], references: [id], onDelete: Cascade)
  cardId               String
  card                 Card        @relation(fields: [cardId], references: [id], onDelete: Cascade)
  grade                ReviewGrade
  previousIntervalDays Int?
  newIntervalDays      Int
  reviewedAt           DateTime    @default(now())

  @@index([userId, reviewedAt])
  @@index([deckId, reviewedAt])
  @@index([cardId, reviewedAt])
}

model Achievement {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code       String
  title      String
  unlockedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@unique([userId, code])
  @@index([userId])
}

model DailyStudyActivity {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activityDate  DateTime
  reviewsCount  Int      @default(0)
  sessionsCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, activityDate])
  @@index([userId, activityDate])
}

model UserStats {
  userId             String    @id
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak      Int       @default(0)
  longestStreak      Int       @default(0)
  totalReviewedCards Int       @default(0)
  totalStudySessions Int       @default(0)
  lastStudyDate      DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}
